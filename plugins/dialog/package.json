{
  "name": "@vela/plugin-dialog",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Host TS capability plugin: file/folder open and save dialogs (dialog.open / dialog.save)",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
