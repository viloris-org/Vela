{
  "name": "vela",
  "version": "0.0.1",
  "private": true,
  "description": "TypeScript-first GUI framework: WebView UI, Qt-class composition, system materials & capabilities (Bun = toolchain + desktop reference host)",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "typecheck": "bun run --filter @vela/api typecheck",
    "test": "bun test packages/api",
    "test:api": "bun test packages/api",
    "playground:serve": "bun run --filter @vela/playground serve"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  }
}
